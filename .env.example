SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# =============================
# 🌐 App Config
# =============================
FRONTEND_URL=https://repz.app
TRIAL_PERIOD_DAYS=7                      # Default free trial duration (days)
PLAN_COMMISSION_RATE=0.1                 # Platform cut of plan sales (e.g., 0.1 = 10%)
